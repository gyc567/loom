{
  "name": "loom",
  "version": "0.1.0",
  "description": "A delivery layer for coding agents that turns product requests into planned, verified, deployable software changes.",
  "license": "Apache-2.0",
  "bin": {
    "loom": "./dist/cli.js"
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "npm run clean && tsc -p tsconfig.json && chmod +x dist/cli.js",
    "check": "npm run build",
    "verify:phase2-repository-context": "node scripts/verify-phase2-repository-context-flow.js",
    "verify:phase-handoff-git-advisory": "node scripts/verify-phase-handoff-git-advisory.js",
    "verify:next-phase-preview-routing": "node scripts/verify-next-phase-preview-routing.js",
    "verify:layered-self-validation": "node scripts/verify-layered-self-validation.js",
    "verify:review-scope-declared-changed-files": "node scripts/verify-review-scope-declared-changed-files.js",
    "verify:submit-routing-coverage": "node scripts/verify-submit-routing-coverage.js",
    "verify:long-operation-observability": "node scripts/verify-long-operation-observability.js",
    "verify:optional-empty-aac-repair-sections": "node scripts/verify-optional-empty-and-aac-repair-sections.js",
    "verify:phase-aware-source-consistency": "node scripts/verify-phase-aware-source-consistency.js",
    "verify:technical-baseline-reuse-signals": "node scripts/verify-technical-baseline-reuse-signals.js",
    "verify:greenfield-technical-baseline": "node scripts/verify-greenfield-technical-baseline-confirmation.js",
    "verify:brainstorm-business-detail": "node scripts/verify-brainstorm-business-detail-grounding.js",
    "verify:brainstorm-frontend-operation-path": "node scripts/verify-brainstorm-frontend-operation-path.js",
    "verify:next-task-execute-instruction": "node scripts/verify-layered-self-validation.js && node scripts/verify-auto-runnable-transition-contract.js",
    "verify:auto-runnable-transition-contract": "node scripts/verify-auto-runnable-transition-contract.js",
    "verify:aac-coverage-stale-architecture": "node scripts/verify-aac-coverage-and-stale-architecture.js",
    "verify:frontend-runtime-severity": "node scripts/verify-frontend-runtime-severity-protocol.js",
    "verify:frontend-execution-guidance": "node scripts/verify-frontend-execution-guidance.js",
    "verify:workflow-closure-protocol": "node scripts/verify-workflow-closure-protocol.js",
    "verify:compact-output-contract": "node scripts/verify-auto-runnable-transition-contract.js",
    "verify:agent-facing-request-protocol": "node scripts/verify-agent-facing-request-protocol.js",
    "verify:agent-profile-adapters": "node scripts/verify-agent-profile-adapters.js",
    "verify:protocol-boundary-audit": "node scripts/verify-protocol-boundary-audit.js",
    "verify:read-plan-inspect": "node scripts/verify-read-plan-inspect.js",
    "verify:read-plan-size-audit": "node scripts/verify-read-plan-size-audit.js",
    "verify:deploy-preview-validation": "node scripts/verify-deploy-preview-validation.js",
    "verify:requirement-context": "node scripts/verify-requirement-context-keyword-hints.js",
    "agent:e2e-guard": "node scripts/guard-agent-e2e-processes.js",
    "audit:claude-log": "node scripts/audit-claude-loom-session.js",
    "smoke:deploy": "npm run build && node scripts/deploy-smoke-test.js",
    "plugin:install-codex": "npm run build && node scripts/refresh-local-codex-plugin.js",
    "plugin:install-claude": "npm run build && node scripts/refresh-local-claude-plugin.js",
    "plugin:install-opencode": "npm run build && node scripts/refresh-local-opencode-plugin.js",
    "plugin:install-adapters": "npm run build && node scripts/refresh-local-codex-plugin.js && node scripts/refresh-local-claude-plugin.js && node scripts/refresh-local-opencode-plugin.js",
    "plugin:uninstall-codex": "node scripts/uninstall-local-adapter.js codex",
    "plugin:uninstall-claude": "node scripts/uninstall-local-adapter.js claude",
    "plugin:uninstall-opencode": "node scripts/uninstall-local-adapter.js opencode",
    "plugin:uninstall-adapters": "node scripts/uninstall-local-adapter.js all",
    "plugin:install-local": "npm run plugin:install-adapters",
    "plugin:refresh-codex": "npm run plugin:install-codex",
    "plugin:refresh-claude": "npm run plugin:install-claude",
    "plugin:refresh-opencode": "npm run plugin:install-opencode",
    "plugin:refresh-local": "npm run plugin:install-adapters"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "mammoth": "^1.12.0",
    "pdf-parse": "^2.4.5",
    "yaml": "^2.9.0",
    "yauzl": "^3.3.1",
    "zod": "^3.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/yauzl": "^2.10.3",
    "typescript": "^5.0.0"
  }
}
